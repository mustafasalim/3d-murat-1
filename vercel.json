{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/hizmetler", "destination": "/index.html" },
    { "source": "/portfolyo", "destination": "/index.html" },
    { "source": "/iletisim", "destination": "/index.html" },
    { "source": "/teklif-al", "destination": "/index.html" }
  ]
}
